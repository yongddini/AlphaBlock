# Secrets / env
.env

# 개인키 — 원격이 공개 저장소라 `git add -A` 한 번에 유출된다.
# 저장소 루트 ssh/ 에 실제 키가 있었다(추적된 적은 없음). 확장자 글롭도 함께 건다.
ssh/
*.key
*.ppk
*.pem

# Virtual environments
.venv/

# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Data artifacts
data/*.db
# WAL 저널 부산물 (WAN-156 §4) — `data/*.db` 글롭이 잡지 못한다
data/*.db-wal
data/*.db-shm
data/*.parquet
data/*.json

# 1분봉 등 전체 로드 parquet 캐시 (WAN-78) — data/*.parquet는 하위 디렉터리를 잡지 못함
data/cache/

# Report / analysis outputs (backtest·parity·walkforward)
out/

# 상시 구동 데몬 로그 (WAN-31)
logs/

# Local-only Claude Code settings (shared: .claude/settings.json)
.claude/settings.local.json
.claude/worktrees/

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/

# macOS
.DS_Store
.auto-dev.log
