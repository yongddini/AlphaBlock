# AlphaBlock 환경변수 예시. 이 파일을 복사해 `.env`로 만들고 값을 채운다.
# 주의: `.env`는 커밋 금지 (.gitignore 에 포함됨). 실제 키를 이 파일에 넣지 말 것.

# 바이낸스 API 자격 증명 (공개 시세 수집만 하면 비워도 됨)
ALPHABLOCK_BINANCE_API_KEY=
ALPHABLOCK_BINANCE_API_SECRET=

# 시장 유형: spot | future (본 프로젝트는 USDⓈ-M 무기한 선물이 기본)
ALPHABLOCK_MARKET_TYPE=future

# 레거시 단일 심볼 / 타임프레임 (엔트리포인트 요약 등에서 사용)
ALPHABLOCK_SYMBOL=BTC/USDT:USDT
ALPHABLOCK_TIMEFRAME=1h

# 수집 대상 심볼·타임프레임 (JSON 배열). 비우면 코드 기본값 사용.
# 기본: ["BTC/USDT:USDT","ETH/USDT:USDT","SOL/USDT:USDT"]
ALPHABLOCK_SYMBOLS=["BTC/USDT:USDT","ETH/USDT:USDT","SOL/USDT:USDT"]
# 기본: ["1m","5m","15m","1h","4h","1d"]
ALPHABLOCK_TIMEFRAMES=["1m","5m","15m","1h","4h","1d"]

# 타임프레임별 백필 룩백(일). JSON 객체.
ALPHABLOCK_BACKFILL_LOOKBACK_DAYS={"1m":3,"5m":10,"15m":30,"1h":120,"4h":365,"1d":1825}

# 수집 데이터 SQLite 경로 (OHLCV·펀딩비 공용)
ALPHABLOCK_DB_PATH=data/ohlcv.db

# 펀딩비(funding rate) 수집 설정
ALPHABLOCK_FUNDING_ENABLED=true
# 현재 펀딩비/다음 정산 시각 갱신 간격(초). 예: 300(5분) ~ 900(15분)
ALPHABLOCK_FUNDING_REFRESH_INTERVAL_SECONDS=300
# 저장분이 없을 때 펀딩 이력을 백필할 룩백(일)
ALPHABLOCK_FUNDING_BACKFILL_LOOKBACK_DAYS=30

# 전략 규칙(WAN-23): 진입=오더블록+RSI, 익절=EMA/VWMA 선 도달, 손절=오더블록 무효화.
# 중첩 필드는 `__`로 접근한다. 기본값은 사용자 트레이딩뷰 설정과 일치하므로 보통
# 비워둔다. 조정 예시:
# 진입 RSI(필수 조건): 롱은 RSI<=oversold, 숏은 RSI>=overbought일 때만 진입
# ALPHABLOCK_CONFLUENCE__RSI_LENGTH=14
# ALPHABLOCK_CONFLUENCE__RSI_OVERBOUGHT=70
# ALPHABLOCK_CONFLUENCE__RSI_OVERSOLD=30
# 익절 목표선(EMA 배열 + VWMA). VWMA 미사용 시 빈 값이 아니라 필드를 지워야 함
# ALPHABLOCK_CONFLUENCE__TP_EMA_LENGTHS=[20,60,120,240,365]
# ALPHABLOCK_CONFLUENCE__TP_VWMA_LENGTH=100
# ALPHABLOCK_CONFLUENCE__USE_LINE_TAKE_PROFIT=true
# 손절(오더블록 무효화) on/off, 동일 봉 동시 충족 시 손절 우선
# ALPHABLOCK_CONFLUENCE__USE_ORDER_BLOCK_STOP=true
# ALPHABLOCK_CONFLUENCE__STOP_BEFORE_TAKE_PROFIT=true

# 실시간 시그널 러너 + 텔레그램 알림 (WAN-25, 페이퍼 모드 — 실주문 없음)
# 비밀값(봇 토큰)은 이 파일에 넣지 말 것. 발급 절차는 README "실시간 시그널 러너" 참고.
ALPHABLOCK_TELEGRAM_BOT_TOKEN=
ALPHABLOCK_TELEGRAM_CHAT_ID=
# 러너가 감시할 심볼·타임프레임 (JSON 배열, 수집 대상의 부분집합). 기본: BTC 1h.
ALPHABLOCK_LIVE_SIGNAL_SYMBOLS=["BTC/USDT:USDT"]
ALPHABLOCK_LIVE_SIGNAL_TIMEFRAMES=["1h"]
# 저장소 폴링 간격(초)과 전략 재평가에 쓸 최근 봉 수.
ALPHABLOCK_LIVE_POLL_INTERVAL_SECONDS=60
ALPHABLOCK_LIVE_SIGNAL_LOOKBACK_BARS=1500
# 재시작 시 중복 발송을 막는 워터마크 상태 파일 경로 (커밋 금지, data/*.json 무시됨).
ALPHABLOCK_LIVE_SIGNAL_STATE_PATH=data/live_signals_state.json

# 리스크 기반 포지션 사이징 (WAN-26). 손절 거리(오더블록 distal 경계)에 반비례해
# 수량을 역산한다. 백테스트·실행 공용. 기본 켬. 중첩 필드는 `__`로 접근한다.
ALPHABLOCK_RISK_SIZING_ENABLED=true
# 거래당 리스크 = 자본 × risk_per_trade (예: 0.01 = 1%)
# ALPHABLOCK_RISK_SIZING__RISK_PER_TRADE=0.01
# 레버리지 상한 (명목가치 ≤ 자본 × leverage)
# ALPHABLOCK_RISK_SIZING__LEVERAGE=1.0
# 추가 명목가치 상한 = 자본 × 이 값 (미설정 시 leverage만 상한)
# ALPHABLOCK_RISK_SIZING__MAX_NOTIONAL_FRACTION=1.0
# 최소 주문 수량 단위(lot). 산출 수량을 이 배수로 내림. 0=반올림 없음
# ALPHABLOCK_RISK_SIZING__QTY_STEP=0.0
# 최소 주문 수량. 내림 후 이 값 미만이면 진입 스킵
# ALPHABLOCK_RISK_SIZING__MIN_QTY=0.0
# 진입가 대비 최소 손절 거리(분수). 손절이 이보다 가까우면 진입 스킵
# ALPHABLOCK_RISK_SIZING__MIN_STOP_DISTANCE_FRACTION=0.0

# 실거래 실행 여부 (반드시 검증 전까지 false 유지 — 본 데이터 이슈에서는 미사용)
ALPHABLOCK_LIVE_TRADING=false
