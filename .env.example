# AlphaBlock 환경변수 예시. 이 파일을 복사해 `.env`로 만들고 값을 채운다.
# 주의: `.env`는 커밋 금지 (.gitignore 에 포함됨). 실제 키를 이 파일에 넣지 말 것.

# 바이낸스 API 자격 증명
ALPHABLOCK_BINANCE_API_KEY=
ALPHABLOCK_BINANCE_API_SECRET=

# 시장 유형: spot | future
ALPHABLOCK_MARKET_TYPE=spot

# 기본 심볼 / 타임프레임
ALPHABLOCK_SYMBOL=BTC/USDT
ALPHABLOCK_TIMEFRAME=1h

# 실거래 실행 여부 (반드시 검증 전까지 false 유지)
ALPHABLOCK_LIVE_TRADING=false
