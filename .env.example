# AlphaBlock 환경변수 예시. 이 파일을 복사해 `.env`로 만들고 값을 채운다.
# 주의: `.env`는 커밋 금지 (.gitignore 에 포함됨). 실제 키를 이 파일에 넣지 말 것.

# 바이낸스 API 자격 증명 (공개 시세 수집만 하면 비워도 됨)
ALPHABLOCK_BINANCE_API_KEY=
ALPHABLOCK_BINANCE_API_SECRET=

# 바이낸스 선물 테스트넷 (WAN-27). 실계좌 실거래 전 안전 검증용.
# true면 create_exchange가 set_sandbox_mode로 테스트넷 엔드포인트를 쓰고, 아래 testnet
# 키만 주입한다(위 실계좌 키는 테스트넷 경로로 절대 사용되지 않음). 기본은 false.
# 테스트넷 키 발급: https://testnet.binancefuture.com
ALPHABLOCK_USE_TESTNET=false
ALPHABLOCK_TESTNET_API_KEY=
ALPHABLOCK_TESTNET_API_SECRET=

# 시장 유형: spot | future (본 프로젝트는 USDⓈ-M 무기한 선물이 기본)
ALPHABLOCK_MARKET_TYPE=future

# 레거시 단일 심볼 / 타임프레임 (엔트리포인트 요약 등에서 사용)
ALPHABLOCK_SYMBOL=BTC/USDT:USDT
ALPHABLOCK_TIMEFRAME=1h

# 수집 대상 심볼·타임프레임 (JSON 배열). 비우면 코드 기본값 사용.
# 기본: ["BTC/USDT:USDT","ETH/USDT:USDT","SOL/USDT:USDT"]
ALPHABLOCK_SYMBOLS=["BTC/USDT:USDT","ETH/USDT:USDT","SOL/USDT:USDT"]
# 기본: ["1m","5m","15m","1h","4h","1d"]
ALPHABLOCK_TIMEFRAMES=["1m","5m","15m","1h","4h","1d"]

# 타임프레임별 백필 룩백(일). JSON 객체. 저장분이 없을 때 얼마나 과거부터 처음 채울지.
# WAN-51: A/B 본실험(WAN-46) 재현을 위해 분석용 TF(1m·15m·1h)를 3년(1095일)으로 정렬한다.
# 15m 만 1년(365)이라 15m 결과가 전략 탓인지 표본 탓인지 구분이 안 됐다 → 3년으로 통일.
# (코드 폴백 기본값은 과도한 콜드스타트 다운로드를 막기 위해 더 짧다: config/settings.py)
ALPHABLOCK_BACKFILL_LOOKBACK_DAYS={"1m":1095,"15m":1095,"1h":1095,"4h":1460,"1d":1825}

# 수집 데이터 SQLite 경로 (OHLCV·펀딩비 공용)
ALPHABLOCK_DB_PATH=data/ohlcv.db

# 펀딩비(funding rate) 수집 설정
ALPHABLOCK_FUNDING_ENABLED=true
# 현재 펀딩비/다음 정산 시각 갱신 간격(초). 예: 300(5분) ~ 900(15분)
ALPHABLOCK_FUNDING_REFRESH_INTERVAL_SECONDS=300
# 저장분이 없을 때 펀딩 이력을 백필할 룩백(일)
ALPHABLOCK_FUNDING_BACKFILL_LOOKBACK_DAYS=30
# 저장분이 없을 때 이 날짜(ISO)부터 펀딩을 백필한다. 설정하면 룩백일수보다 우선한다.
# 백테스트 구간 전체를 커버하려면 백테스트 시작일로 둔다(WAN-63). 예: 2023-07-01
# ALPHABLOCK_FUNDING_BACKFILL_START=2023-07-01

# 전략 규칙(WAN-81 메인 엔진): 진입=오더블록 탭(볼린저 진입가 재산정)+첫탭 무조건/재탭
# RSI, 익절=고정 1:1.5R, 손절=오더블록 무효화. 중첩 필드는 `__`로 접근한다. 기본값이
# 이미 이 규칙이므로 보통 비워둔다(옛 EMA/VWMA 선 익절 규칙으로 되돌리려면 아래 예시
# 참고). 조정 예시:
# 진입 RSI: 첫 탭(존 확정 후 처음 닿는 순간)은 RSI 무관 무조건 진입, 재탭부터
# 롱 RSI<=oversold / 숏 RSI>=overbought (rsi_gate_mode="first_tap_free", 기본).
# ALPHABLOCK_CONFLUENCE__RSI_LENGTH=14
# ALPHABLOCK_CONFLUENCE__RSI_OVERBOUGHT=70
# ALPHABLOCK_CONFLUENCE__RSI_OVERSOLD=30
# 존당 재진입 허용 여부. 기본 "every_tap"(존이 무효화되기 전까지 매 탭마다 진입
# 평가, combine_obs=true면 병합 존 경계 기준). "once"면 첫 탭 1회만(구 엔진).
# ALPHABLOCK_CONFLUENCE__RETAP_MODE=every_tap
# RSI 게이트 방향. 기본 "first_tap_free"(위 설명). "extreme"이면 모든 탭에 항상
# 극단 규칙 적용(구 엔진). 그 외 "neutral"/"none"은 docstring(strategy/models.py) 참고.
# ALPHABLOCK_CONFLUENCE__RSI_GATE_MODE=first_tap_free
# 익절 목표 산정 방식. 기본 "fixed_r"(진입가~오더블록 무효화 경계 거리의
# TAKE_PROFIT_R배를 고정 익절가로). "line"이면 구 엔진의 EMA/VWMA 선 도달 익절.
# ALPHABLOCK_CONFLUENCE__TAKE_PROFIT_MODE=fixed_r
# ALPHABLOCK_CONFLUENCE__TAKE_PROFIT_R=1.5
# 익절 판정선(EMA 배열 + VWMA) — take_profit_mode="line"일 때만 쓴다(WAN-66: 기본은
# EMA 60 + VWMA 100 두 개뿐). EMA 20/120/240/365는 차트에만 그리는 표시선이지 익절
# 판정에 쓰지 않는다(아래 DISPLAY_ 참고).
# ALPHABLOCK_CONFLUENCE__TP_EMA_LENGTHS=[60]
# ALPHABLOCK_CONFLUENCE__TP_VWMA_LENGTH=100
# ALPHABLOCK_CONFLUENCE__USE_LINE_TAKE_PROFIT=false
# 차트 표시선(대시보드 오버레이 전용, 익절 판정과 무관 — WAN-66)
# ALPHABLOCK_CONFLUENCE__DISPLAY_EMA_LENGTHS=[20,60,120,240,365]
# 진입가 재산정: SMA/종가 대비 이격 필터. 기본은 볼린저밴드(SMA 20 ± 2σ) 켜짐(WAN-81) —
# 밴드가 존 위/겹침/아래에 있을 때 각각 근단 진입/밴드 진입/진입 없음. 2단 중첩이라
# 환경변수(`__` 1단만 지원)로는 조정할 수 없다 — 끄거나 바꾸려면 코드에서
# `ConfluenceParams(deviation_filter=...)`로 직접 덮어쓴다(strategy/models.py 참고).
# 숏(약세 오더블록) 진입 허용 여부. 기본 true(WAN-81 — WAN-69의 롱 온리 결정을
# 사용자 확정 규칙으로 뒤집음). 끄려면 false로.
# ALPHABLOCK_CONFLUENCE__SHORT_ENABLED=true
# 손절(오더블록 무효화) on/off, 동일 봉 동시 충족 시 손절 우선
# ALPHABLOCK_CONFLUENCE__USE_ORDER_BLOCK_STOP=true
# ALPHABLOCK_CONFLUENCE__STOP_BEFORE_TAKE_PROFIT=true

# 실시간 시그널 러너 + 텔레그램 알림 (WAN-25, 페이퍼 모드 — 실주문 없음)
# 비밀값(봇 토큰)은 이 파일에 넣지 말 것. 발급 절차는 README "실시간 시그널 러너" 참고.
ALPHABLOCK_TELEGRAM_BOT_TOKEN=
ALPHABLOCK_TELEGRAM_CHAT_ID=
# 러너가 감시할 심볼·타임프레임 (JSON 배열, 수집 대상의 부분집합). 기본: BTC 1h.
ALPHABLOCK_LIVE_SIGNAL_SYMBOLS=["BTC/USDT:USDT"]
ALPHABLOCK_LIVE_SIGNAL_TIMEFRAMES=["1h"]
# 저장소 폴링 간격(초)과 전략 재평가에 쓸 최근 봉 수.
ALPHABLOCK_LIVE_POLL_INTERVAL_SECONDS=60
ALPHABLOCK_LIVE_SIGNAL_LOOKBACK_BARS=1500
# 재시작 시 중복 발송을 막는 워터마크 상태 파일 경로 (커밋 금지, data/*.json 무시됨).
ALPHABLOCK_LIVE_SIGNAL_STATE_PATH=data/live_signals_state.json
# 러너 운영 상태(하트비트·페이퍼 포지션·최근 신호)를 남겨 Health 대시보드(WAN-30)가
# 읽는 파일 경로 (커밋 금지). 러너가 매 폴링마다 갱신한다.
ALPHABLOCK_LIVE_RUNTIME_STATE_PATH=data/live_runtime_state.json
# Health 신선도 판정 배수: 최신 봉/펀딩/러너 지연이 주기의 이 배수를 넘으면 stale 경고.
ALPHABLOCK_HEALTH_STALE_MULTIPLIER=2.5

# 상시 구동 수집기(WAN-31) 하트비트. 수집기가 살아있음을 남기는 파일(커밋 금지,
# data/*.json 무시됨)과, Health 생존 판정에 쓰는 기대 하트비트 간격(초).
# min_interval 은 파일 쓰기 스로틀(수신 메시지마다 쓰지 않도록).
ALPHABLOCK_COLLECTOR_HEARTBEAT_PATH=data/collector_heartbeat.json
ALPHABLOCK_COLLECTOR_HEARTBEAT_INTERVAL_SECONDS=60
ALPHABLOCK_COLLECTOR_HEARTBEAT_MIN_INTERVAL_SECONDS=5

# 운영 상태(Health) 워치 (WAN-32). WAN-30 판정을 주기적으로 점검해 데이터/러너/수집기가
# 멈추면 텔레그램 경고를 보낸다(`alphablock watch`). stale 판정 배수는 위
# ALPHABLOCK_HEALTH_STALE_MULTIPLIER 를 공유한다.
# 점검 주기(초). 쿨다운(초): 동일 이상은 이 시간 내 1회만 경고(플래핑 방지).
ALPHABLOCK_HEALTH_WATCH_INTERVAL_SECONDS=600
ALPHABLOCK_HEALTH_WATCH_COOLDOWN_SECONDS=3600
# 발효 중인 경고 상태 파일(커밋 금지, data/*.json 무시됨). 재시작 시 중복/누락 방지.
ALPHABLOCK_HEALTH_WATCH_STATE_PATH=data/health_watch_state.json

# 대시보드 상시 구동·자동 새로고침 (WAN-48). launchd 데몬(install-daemons.sh dashboard)으로
# 상주시켜 터미널 없이 http://localhost:<PORT> 북마크로 확인한다. PORT는 설치 스크립트가
# 읽어 plist에 싣고(127.0.0.1 로만 바인딩), REFRESH_SECONDS는 대시보드가 읽어 운영 상태
# 탭을 그 주기로 자동 갱신한다(0이면 자동 갱신 끔). 대시보드는 읽기 전용이다.
ALPHABLOCK_DASHBOARD_PORT=8501
ALPHABLOCK_DASHBOARD_REFRESH_SECONDS=60

# 페이퍼 성과 다이제스트 (WAN-36). paper_trades(WAN-33)에서 한 기간 성과 요약을 만들어
# 텔레그램으로 주기적으로 보낸다(`scripts/paper_digest.py`). 실제 발송은 아래가 true이고
# ALPHABLOCK_TELEGRAM_* 가 설정된 경우에만 한다(기본 끔). --dry-run 은 설정과 무관하게 미리보기.
ALPHABLOCK_PAPER_DIGEST_ENABLED=false
# --since 미지정 시 기본 집계 창(일). 주 1회 실행이면 7.
ALPHABLOCK_PAPER_DIGEST_DAYS=7
# 스케줄러(cron/launchd)가 참고할 발송 요일(0=월 … 6=일)·시각(UTC 시). 스크립트 자체는 스케줄링하지 않는다.
ALPHABLOCK_PAPER_DIGEST_WEEKDAY=0
ALPHABLOCK_PAPER_DIGEST_HOUR_UTC=0
# OHLCV 갭 자동 탐지·복구 백필 (WAN-35). 저장된 시리즈의 내부 누락 봉을 찾아 그 구간만
# 재수집한다. 수집 데몬(`alphablock collect`) 시작 시 1회 자동 점검(repair_on_start, 기본
# 켬)과, 마지막 복구 요약 파일(커밋 금지, data/*.json 무시됨) 경로.
ALPHABLOCK_REPAIR_ON_START=true
ALPHABLOCK_REPAIR_STATE_PATH=data/repair_state.json

# 리스크 기반 포지션 사이징 (WAN-26). 손절 거리(오더블록 distal 경계)에 반비례해
# 수량을 역산한다. 백테스트·실행 공용. 기본 켬. 중첩 필드는 `__`로 접근한다.
ALPHABLOCK_RISK_SIZING_ENABLED=true
# 거래당 리스크 = 자본 × risk_per_trade (예: 0.01 = 1%)
# ALPHABLOCK_RISK_SIZING__RISK_PER_TRADE=0.01
# 레버리지 상한 (명목가치 ≤ 자본 × leverage)
# ALPHABLOCK_RISK_SIZING__LEVERAGE=1.0
# 추가 명목가치 상한 = 자본 × 이 값 (미설정 시 leverage만 상한)
# ALPHABLOCK_RISK_SIZING__MAX_NOTIONAL_FRACTION=1.0
# 최소 주문 수량 단위(lot). 산출 수량을 이 배수로 내림. 0=반올림 없음
# ALPHABLOCK_RISK_SIZING__QTY_STEP=0.0
# 최소 주문 수량. 내림 후 이 값 미만이면 진입 스킵
# ALPHABLOCK_RISK_SIZING__MIN_QTY=0.0
# 진입가 대비 최소 손절 거리(분수). 손절이 이보다 가까우면 진입 스킵.
# 기본값 0.003(0.3%)은 신뢰성 가드(WAN-79). 0으로 두면 하한이 꺼진다.
# ALPHABLOCK_RISK_SIZING__MIN_STOP_DISTANCE_FRACTION=0.003

# 실행 리스크 한도 (WAN-9). 사이징(WAN-26)과 별개로 신규 진입을 차단하는 상한.
# 중첩 필드는 `__`로 접근한다.
# 총 명목가치 상한 = 자본 × max_leverage
# ALPHABLOCK_RISK_LIMITS__MAX_LEVERAGE=1.0
# 추가 명목 상한 = 자본 × 이 값 (미설정 시 max_leverage만 상한)
# ALPHABLOCK_RISK_LIMITS__MAX_NOTIONAL_FRACTION=1.0
# 동시에 열 수 있는 오픈 포지션 최대 수
# ALPHABLOCK_RISK_LIMITS__MAX_CONCURRENT_POSITIONS=1
# 일일 손실 서킷브레이커 한도 = 기준자본 × 이 값. 하루 누적 손실이 넘으면 그날 진입 차단
# ALPHABLOCK_RISK_LIMITS__DAILY_LOSS_LIMIT_FRACTION=0.05
# 실행 엔진(페이퍼) 시작 자본. 리스크·사이징·손익 정산의 기준
# ALPHABLOCK_PAPER_EQUITY=10000.0
# 체결 비용 모델(WAN-37): 메이커/테이커 수수료 + 슬리피지의 단일 소스.
# 백테스트와 페이퍼가 이 값을 공유해 패리티 비교를 유의미하게 한다.
# 테이커(시장가) 수수료율. 기본 0.04%
# ALPHABLOCK_COSTS__TAKER_FEE_RATE=0.0004
# 메이커(지정가) 수수료율. 기본 0.02%
# ALPHABLOCK_COSTS__MAKER_FEE_RATE=0.0002
# 테이커 체결 슬리피지(bps). 메이커(지정가) 체결에는 적용 안 함. 기본 5bps=0.05%
# ALPHABLOCK_COSTS__SLIPPAGE_BPS=5.0

# 실거래 실행 여부 (반드시 검증 전까지 false 유지). true여도 실행 엔진은 실거래
# 브로커를 자동 생성하지 않고 명시적 주입을 요구한다(실계좌 연결·검증은 WAN-27).
ALPHABLOCK_LIVE_TRADING=false
